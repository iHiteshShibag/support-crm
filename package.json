{
  "name": "support-crm",
  "version": "1.0.0",
  "description": "Full-stack customer support ticketing CRM built with Node.js, Express, SQLite, and React.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "keywords": [
    "crm",
    "support",
    "tickets",
    "express",
    "sqlite",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.13.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": "20.19.0"
  }
}
